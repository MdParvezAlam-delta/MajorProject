<% layout("/layouts/boilerplate")%> 
  <body>

    <!-- ---------------------------------------------------------------------------------------------------------------- -->

    <!-- <h1>All Listings</h1> -->

    <!-- I have commentout it bcz I have usee add new listing achor tag  version in nav bar  -->
    <!-- <form method="GET" action="/listings/new">
      <button>Create New Listing</button>
    </form> -->
    <!-- ---------------------------------------------------------------------------------------------------------------- -->

<style>
#filters{
  display: flex;
flex-wrap: wrap;
align-items: center;

}

.filter{
  text-align: center;
  margin-right: 2rem;
  margin-top:2rem;
  opacity:0.7;
}

.filter:hover{
  opacity: 1;
  cursor: pointer;
  color: gold;
  
}

.tax-info{
  display: none;
}

.filter p{
  font-size: 0.6rem;
}


.tax-toggle{
  border: 1px solid black;
  border-radius: 1rem;
  height: 3.25rem;
  margin-top:0.5rem;
  padding: 1rem;
  margin-left: 5rem;
  font-size: 1rem;
 display: flex;
  align-items: center;
  background: linear-gradient(90deg, #fd3f3f 0%, #8d47ff 100%);

}
</style> 
   
  <!-- !- ---------------------------------------------------------------------------------------------------------------- -->
  <div id="filters">

    <!-- -------------------- filterization code -------------------- -->
    <!-- these links send category query to /listings route -->
    <a href="/listings?category=trending" class="filter text-decoration-none">
      <div><i class="fa-solid fa-fire-flame-curved"></i></div>
      <p> Trendings</p>
    </a>
<!-- ----------------------------------------- -->
    <a href="/listings?category=frequently-search" class="filter text-decoration-none">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Frequently Search</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=wifi" class="filter text-decoration-none">
      <div><i class="fa-solid fa-wifi"></i></div>
      <p>Free-WiFi</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=beach" class="filter text-decoration-none">
      <div><i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Beach</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=wow" class="filter text-decoration-none">
      <div><i class="fa-solid fa-rocket"></i></div>
      <p>wow!</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=cities" class="filter text-decoration-none">
      <div><i class="fa-solid fa-building-wheat"></i></div>
      <p>cities</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=forest" class="filter text-decoration-none">
      <div><i class="fa-solid fa-tree"></i></div>
      <p>forest</p>
    </a>
<!-- ----------------------------------------- -->

    <a href="/listings?category=house" class="filter text-decoration-none">
      <div><i class="fa-solid fa-house"></i></div>
      <p>house</p>
    </a>
<!-- ----------------------------------------- -->

  <!-- tax-toggle -->

  <div class="tax-toggle">
      <div class="form-check form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
</div>
    </div>
<!-- ----------------------------------------- -->

    </div> 
    <!-- ---------------------------------------------------------------------------------------------------------------- -->


 <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 mt-3">

   <!-- (this row div is given to arrange image in row wise)  -->
    <!-- %= listing.image.url %> this code fetch image from databases -->

 <% for(let listing of allListings) { %>

  <!-- (all the card div inside achor tag . so that we can go to show-route by clicking card) -->
   <!-- (class="listing-link"> I have creatrd this class for removes
    the underline from imag-title by text-decoration:none) -->

  <a href="/listings/<%= listing._id %>" class="listing-link">

 <div class="card col listing-card">

  <img src="<%= listing.image.url %>"
   class="card-img-top" 
   alt="listing-img"
  style="height:15rem"
  >
  <!-- this code [ style="height:15rem"
] helps to give same height of image to all the image -->

<!-- (<div class="card-img-overlay"></div> : helps to provide overlay effect) -->

<div class="card-img-overlay">🐳  🎀  SARA SULTANA  🎀  🐳</div>
  <div class="card-body">
    <p class="card-text">
      <%= listing.title %> <br>
&#8377;<%= listing.price != null ? listing.price.toLocaleString("en-IN") : "Price not available" %> 
<i class="tax-info">&nbsp;&nbsp; +18% GST</i>
    </p>
  </div>
</div>
</a>

      <% } %> 

</div>

<!-- ---------------------------------------------------------------------------------------------------------------- -->

  <script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", ()=>{
 let taxinfo = document.getElementsByClassName("tax-info");

   for (info of taxinfo){

 if (info.style.display != "inline"){
     info.style.display = "inline";
   }
  
  else{
    info.style.display = "none";
  }
}
    })
  </script>